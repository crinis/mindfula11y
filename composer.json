{
    "name": "mindfulmarkup/mindfula11y",
    "description": "Find and fix accessibility issues in TYPO3: missing-alt detection and AI alt-text generation, decorative-image controls, heading/landmark checks, axe-core scans with optional AI audits, semantic Fluid ViewHelpers, and accessible form-validation feedback.",
    "type": "typo3-cms-extension",
    "license": ["GPL-2.0-or-later"],
    "authors": [
        {
            "name": "Felix Spittel",
            "role": "Developer",
            "homepage": "https://www.mindfulmarkup.de"
        }
    ],
    "support": {
        "issues": "https://github.com/crinis/mindfula11y/issues",
        "source": "https://github.com/crinis/mindfula11y"
    },
    "require": {
        "php": ">=8.2 <8.5",
        "typo3/cms-core": "~13.4.18 || ^14.3",
        "typo3/cms-backend": "~13.4.18 || ^14.3",
        "typo3/cms-fluid": "~13.4.18 || ^14.3",
        "typo3/cms-frontend": "~13.4.18 || ^14.3",
        "typo3/cms-extbase": "~13.4.18 || ^14.3",
        "typo3/cms-install": "~13.4.18 || ^14.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "typo3/testing-framework": "^9.2",
        "typo3/cms-workspaces": "~13.4.18 || ^14.3"
    },
    "suggest": {
        "typo3/cms-form": "Adds the localized page-title error prefix after failed server-side EXT:form validation."
    },
    "autoload": {
        "psr-4": {
            "MindfulMarkup\\MindfulA11y\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MindfulMarkup\\MindfulA11y\\Tests\\": "Tests/"
        }
    },
    "scripts": {
        "test": ["@test:unit", "@test:functional"],
        "test:unit": "phpunit",
        "test:functional": "phpunit -c phpunit.functional.xml.dist"
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "mindfula11y"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": false,
            "typo3/class-alias-loader": false
        }
    },
    "keywords": [
        "TYPO3",
        "accessibility",
        "a11y",
        "alt text",
        "headings",
        "landmarks",
        "ARIA",
        "WCAG",
        "backend module",
        "chatgpt",
        "AI generation",
        "semantic HTML",
        "screen reader",
        "extension"
    ]
}

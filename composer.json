{
    "name": "mindfulmarkup/mindfula11y",
    "description": "Find and fix accessibility issues directly in the TYPO3 backend: a remediation module with missing alt-text detection and AI generation (OpenAI), accessibility fields and Fluid ViewHelpers for semantic headings and landmarks, plus optional axe-core page scanning.",
    "type": "typo3-cms-extension",
    "license": ["GPL-2.0-or-later"],
    "authors": [
        {
            "name": "Felix Spittel",
            "role": "Developer",
            "homepage": "https://www.mindfulmarkup.de"
        }
    ],
    "support": {
        "issues": "https://github.com/crinis/mindfula11y/issues",
        "source": "https://github.com/crinis/mindfula11y"
    },
    "require": {
        "php": ">=8.2 <=8.4",
        "typo3/cms-core": "^13.4 || ^14.3",
        "typo3/cms-backend": "^13.4 || ^14.3",
        "typo3/cms-fluid": "^13.4 || ^14.3",
        "typo3/cms-frontend": "^13.4 || ^14.3",
        "typo3/cms-extbase": "^13.4 || ^14.3",
        "typo3/cms-install": "^13.4 || ^14.3"
    },
    "suggest": {
        "typo3/cms-form": "Adds the localized page-title error prefix after failed server-side EXT:form validation."
    },
    "autoload": {
        "psr-4": {
            "MindfulMarkup\\MindfulA11y\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "mindfula11y"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": false,
            "typo3/class-alias-loader": false
        }
    },
    "keywords": [
        "TYPO3",
        "accessibility",
        "a11y",
        "alt text",
        "headings",
        "landmarks",
        "ARIA",
        "WCAG",
        "backend module",
        "chatgpt",
        "AI generation",
        "semantic HTML",
        "screen reader",
        "extension"
    ]
}

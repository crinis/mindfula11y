<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<xliff version="1.2" xmlns="urn:oasis:names:tc:xliff:document:1.2">
	<file source-language="en" target-language="de" datatype="plaintext"
		original="EXT:mindfula11y/Resources/Private/Language/Database.xlf"
		date="2020-11-16T10:32:58Z"
		product-name="mindfula11y">
		<header />
		<body>
			<trans-unit id="sysFileReference.columns.mindfula11y.decorative" resname="sysFileReference.columns.mindfula11y.decorative">
				<source>Decorative image</source>
				<target>Dekoratives Bild</target>
			</trans-unit>
			<trans-unit id="sysFileReference.columns.mindfula11y.decorative.description" resname="sysFileReference.columns.mindfula11y.decorative.description">
				<source>Enable only when this image adds no information and should be ignored by assistive technology. Saving removes alternative text and the title stored on this reference. A visible caption can still be provided in the description field.</source>
				<target>Nur aktivieren, wenn dieses Bild keine Informationen vermittelt und von assistiven Technologien ignoriert werden soll. Beim Speichern werden Alternativtext und Titel dieser Referenz entfernt. Eine sichtbare Bildunterschrift kann weiterhin im Beschreibungsfeld angegeben werden.</target>
			</trans-unit>
			<!-- Corrected mindfulA11y -> mindfula11y in ids/resnames for heading type entries -->
			<trans-unit id="ttContent.columns.mindfula11y.headingType" resname="ttContent.columns.mindfula11y.headingType">
				<source>Heading level</source>
				<target>Überschriftenebene</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.headingType.description" resname="ttContent.columns.mindfula11y.headingType.description">
				<source>Choose this heading's place in the page structure, not its visual size. Use level 1 for the page heading, level 2 for main sections, and increase one level at a time. Choose "Paragraph — not a heading" only when the text does not introduce a section.</source>
				<target>Wählen Sie die Position dieser Überschrift in der Seitenstruktur, nicht ihre visuelle Größe. Verwenden Sie Ebene 1 für die Seitenüberschrift, Ebene 2 für Hauptabschnitte und erhöhen Sie jeweils um eine Ebene. Wählen Sie „Absatz — keine Überschrift“ nur, wenn der Text keinen Abschnitt einleitet.</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.headingType.items.h1" resname="ttContent.columns.mindfula11y.headingType.items.h1">
				<source>Level 1 (H1) — page heading</source>
				<target>Ebene 1 (H1) — Seitenüberschrift</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.headingType.items.h2" resname="ttContent.columns.mindfula11y.headingType.items.h2">
				<source>Level 2 (H2)</source>
				<target>Ebene 2 (H2)</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.headingType.items.h3" resname="ttContent.columns.mindfula11y.headingType.items.h3">
				<source>Level 3 (H3)</source>
				<target>Ebene 3 (H3)</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.headingType.items.h4" resname="ttContent.columns.mindfula11y.headingType.items.h4">
				<source>Level 4 (H4)</source>
				<target>Ebene 4 (H4)</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.headingType.items.h5" resname="ttContent.columns.mindfula11y.headingType.items.h5">
				<source>Level 5 (H5)</source>
				<target>Ebene 5 (H5)</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.headingType.items.h6" resname="ttContent.columns.mindfula11y.headingType.items.h6">
				<source>Level 6 (H6)</source>
				<target>Ebene 6 (H6)</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.headingType.items.p" resname="ttContent.columns.mindfula11y.headingType.items.p">
				<source>Paragraph — not a heading</source>
				<target>Absatz — keine Überschrift</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.headingType.items.div" resname="ttContent.columns.mindfula11y.headingType.items.div">
				<source>Neutral container — no heading meaning (div)</source>
				<target>Neutraler Container — keine Überschriftenbedeutung (div)</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.childHeadingType" resname="ttContent.columns.mindfula11y.childHeadingType">
				<source>Headings inside this element</source>
				<target>Überschriften innerhalb dieses Elements</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.childHeadingType.description" resname="ttContent.columns.mindfula11y.childHeadingType.description">
				<source>Choose the level used for headings in content elements inside this element. "Automatic — next level" follows the page structure by using one level below this element's heading. Change it only when the heading preview shows an incorrect level.</source>
				<target>Wählen Sie die Ebene für Überschriften in Inhaltselementen innerhalb dieses Elements. „Automatisch — nächste Ebene“ folgt der Seitenstruktur und verwendet eine Ebene unterhalb der Überschrift dieses Elements. Ändern Sie die Einstellung nur, wenn die Überschriftenvorschau eine falsche Ebene zeigt.</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.childHeadingType.items.automatic" resname="ttContent.columns.mindfula11y.childHeadingType.items.automatic">
				<source>Automatic — next level</source>
				<target>Automatisch — nächste Ebene</target>
			</trans-unit>

			<!-- Accessibility Tab -->
			<trans-unit id="ttContent.tabs.accessibility"
				resname="ttContent.tabs.accessibility">
				<source>Accessibility</source>
				<target>Barrierefreiheit</target>
			</trans-unit>
			
			<!-- Landmarks Palette -->
			<trans-unit id="ttContent.palettes.landmarks"
				resname="ttContent.palettes.landmarks">
				<source>ARIA Landmarks</source>
				<target>ARIA-Landmarks</target>
			</trans-unit>
			
			<!-- Landmark Field -->
			<trans-unit id="ttContent.columns.mindfula11y.landmark"
				resname="ttContent.columns.mindfula11y.landmark">
				<source>Landmark Type</source>
				<target>Landmark-Typ</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.landmark.description"
				resname="ttContent.columns.mindfula11y.landmark.description">
				<source>Choose how this content should be identified to screen reader users for easier page navigation. Only select a landmark type if this content represents a distinct, meaningful section of the page.</source>
				<target>Wählen Sie, wie dieser Inhalt für Screenreader-Nutzer zur einfacheren Seitennavigation identifiziert werden soll. Wählen Sie nur dann einen Landmark-Typ, wenn dieser Inhalt einen eigenständigen, bedeutsamen Seitenbereich darstellt.</target>
			</trans-unit>
			
			<!-- Landmark Type Options -->
			<trans-unit id="ttContent.columns.mindfula11y.landmark.items.none"
				resname="ttContent.columns.mindfula11y.landmark.items.none">
				<source>None</source>
				<target>Keine</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.landmark.items.region"
				resname="ttContent.columns.mindfula11y.landmark.items.region">
				<source>Important Section (only if none of the other options apply)</source>
				<target>Wichtiger Bereich (nur wenn keine der anderen Optionen zutrifft)</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.landmark.items.navigation"
				resname="ttContent.columns.mindfula11y.landmark.items.navigation">
				<source>Navigation Menu</source>
				<target>Navigationsmenü</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.landmark.items.complementary"
				resname="ttContent.columns.mindfula11y.landmark.items.complementary">
				<source>Sidebar / Related Content</source>
				<target>Seitenleiste / Verwandte Inhalte</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.landmark.items.main"
				resname="ttContent.columns.mindfula11y.landmark.items.main">
				<source>Main Content Area</source>
				<target>Hauptinhaltsbereich</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.landmark.items.banner"
				resname="ttContent.columns.mindfula11y.landmark.items.banner">
				<source>Site Header</source>
				<target>Seitenkopf</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.landmark.items.contentinfo"
				resname="ttContent.columns.mindfula11y.landmark.items.contentinfo">
				<source>Site Footer</source>
				<target>Seitenfuß</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.landmark.items.search"
				resname="ttContent.columns.mindfula11y.landmark.items.search">
				<source>Search Function</source>
				<target>Suchfunktion</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.landmark.items.form"
				resname="ttContent.columns.mindfula11y.landmark.items.form">
				<source>Form Section</source>
				<target>Formularabschnitt</target>
			</trans-unit>
			
			<!-- ARIA Labelledby Field -->
			<trans-unit id="ttContent.columns.mindfula11y.ariaLabelledby"
				resname="ttContent.columns.mindfula11y.ariaLabelledby">
				<source>Use header as landmark name</source>
				<target>Überschrift als Landmark-Name verwenden</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.ariaLabelledby.description"
				resname="ttContent.columns.mindfula11y.ariaLabelledby.description">
				<source>When enabled, the content element's header will be used as the accessible name for this landmark. IMPORTANT: Make sure your content element has a meaningful header when this option is enabled, as screen readers will announce it as the landmark's name.</source>
				<target>Wenn aktiviert, wird die Überschrift des Inhaltselements als zugänglicher Name für dieses Landmark verwendet. WICHTIG: Stellen Sie sicher, dass Ihr Inhaltselement eine aussagekräftige Überschrift hat, wenn diese Option aktiviert ist, da Screenreader sie als Namen des Landmarks vorlesen werden.</target>
			</trans-unit>
			
			<!-- ARIA Label Field -->
			<trans-unit id="ttContent.columns.mindfula11y.ariaLabel"
				resname="ttContent.columns.mindfula11y.ariaLabel">
				<source>Custom landmark name</source>
				<target>Benutzerdefinierter Landmark-Name</target>
			</trans-unit>
			<trans-unit id="ttContent.columns.mindfula11y.ariaLabel.description"
				resname="ttContent.columns.mindfula11y.ariaLabel.description">
				<source>Provide a descriptive name for this landmark that will be announced by screen readers. This should be concise but meaningful, helping users understand the purpose of this section.</source>
				<target>Geben Sie einen beschreibenden Namen für dieses Landmark an, der von Screenreadern vorgelesen wird. Dieser sollte prägnant aber aussagekräftig sein und Nutzern helfen, den Zweck dieses Bereichs zu verstehen.</target>
			</trans-unit>

			<!-- Scan ID Field -->
			<trans-unit id="pages.columns.mindfula11y.scanId"
				resname="pages.columns.mindfula11y.scanId">
				<source>Accessibility Scan ID</source>
				<target>Zugänglichkeit-Scan-ID</target>
			</trans-unit>
			<trans-unit id="pages.columns.mindfula11y.scanId.description"
				resname="pages.columns.mindfula11y.scanId.description">
				<source>External accessibility scan identifier for this page.</source>
				<target>Externe Zugänglichkeits-Scan-Identifikation für diese Seite.</target>
			</trans-unit>
			
			<!-- Scan Last Updated Field -->
			<trans-unit id="pages.columns.mindfula11y.scanUpdated"
				resname="pages.columns.mindfula11y.scanUpdated">
				<source>Scan Updated</source>
				<target>Scan aktualisiert</target>
			</trans-unit>
			<trans-unit id="pages.columns.mindfula11y.scanUpdated.description"
				resname="pages.columns.mindfula11y.scanUpdated.description">
				<source>Timestamp when the accessibility scan ID was last updated.</source>
				<target>Zeitstempel, wann die Zugänglichkeits-Scan-ID zuletzt aktualisiert wurde.</target>
			</trans-unit>
		</body>
	</file>
</xliff>
